.footer {
  text-align: center;
  padding: 1rem 0;
}

.footer-top {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1rem;
}

.footer-nav {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.footer-nav a {
  text-decoration: none;
  color: inherit;
}

.footer-bottom {
  margin-top: 0.5rem;
  font-size: 0.9rem;
}
