---

<footer class="footer">
  <div class="footer-top">
    <nav class="footer-nav">
      <a href="/">Home</a>
      <span>|</span>
      <a href="/portfolio">Portfolio</a>
      <span>|</span>
      <a href="/resume">Resume</a>
      <span>|</span>
