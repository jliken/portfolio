---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .intro {
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      .intro img {
        max-width: 250px;
        height: auto;
        border-radius: 8px;
      }

      .intro-text {
        display: flex;
        flex-direction: column;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="intro">
        <img src="/logos/logo" alt="Profile image" />

        <div class="intro-text">
          <p>
            Hi, I'm Jack Liken &mdash; a soon-to-be Physics graduate at the University of Edinburgh, and prospective aerospace engineer.
          </p>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
