---
const today = new Date();
---

<footer class="footer">
  <div class="footer-top">
    <nav class="footer-nav">
      <a href="/">Home</a>
      <span>|</span>
      <a href="/portfolio">Portfolio</a>
      <span>|</span>
      <a href="/resume">Resume</a>
      <span>|</span>
      <a href="/contact">Contact</a>
    </nav>

    <a href="https://www.linkedin.com/in/jack-liken" target="_blank">
      <img src="/logos/linkedin.png" alt="LinkedIn" width="24" height="24">
    </a>
  </div>

  <div class="footer-bottom">
    &copy; Jack Liken {new Date().getFullYear()}
  </div>
</footer>

<style>
  .footer {
    text-align: center;
    padding: 1rem 0;
    max-height: 120px; /* adjust as needed */
    overflow: hidden;  /* or auto if you want scroll */
  }
  
  /* remove default link styling */
  .footer a {
    color: inherit;
    text-decoration: none;
  }
  
  .footer a:visited {
    color: inherit;
  }
  
  .footer a:hover {
    text-decoration: underline; /* optional */
  }
  
  .footer-top {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }
  
  /* ensure logo aligns with text */
  .footer-top a {
    display: flex;
    align-items: center;
  }
  
  .footer-top img {
    display: block;
  }
  
  .footer-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
</style>
