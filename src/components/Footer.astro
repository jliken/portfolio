    </nav>

    <a href="https://www.linkedin.com/in/jack-liken" target="_blank">
      <img src="/logos/linkedin.png" alt="LinkedIn" width="24" height="24">
    </a>
  </div>

  <div class="footer-bottom">
    &copy; Jack Liken {new Date().getFullYear()}
  </div>
